{
  "name": "@heroku-cli/heroku-connect-plugin",
  "description": "Heroku Connect CLI plugin",
  "version": "0.12.0-beta.0",
  "author": "Heroku",
  "repository": {
    "type": "git",
    "url": "https://github.com/heroku/heroku-connect-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/heroku/heroku-connect-plugin/issues"
  },
  "keywords": [
    "heroku-plugin"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "test": "CONNECT_ADDON=connectqa mocha",
    "posttest": "standard",
    "style-fix": "standard --fix",
    "build": "oclif manifest"
  },
  "files": [
    "/commands",
    "/lib",
    "oclif.manifest.json"
  ],
  "oclif": {
    "bin": "heroku",
    "commands": "./commands",
    "topics": {
      "connect": {
        "description": "manage connections for Heroku Connect"
      },
      "connect:mapping": {
        "description": "manage mappings on a Heroku Connect addon"
      },
      "connect:notifications": {
        "description": "manage notifications on a Heroku Connect addon"
      },
      "connect-events": {
        "description": "manage connections for Heroku Connect Events Pilot"
      },
      "connect-events:stream": {
        "description": "manage mappings on a Heroku Connect Events Pilot addon"
      }
    }
  },
  "dependencies": {
    "@heroku-cli/command": "^12.2.1",
    "@heroku/heroku-cli-util": "^8.0.15",
    "@oclif/core": "^4.8.4",
    "axios": "^1.13.5",
    "heroku-client": "^3.0.6",
    "inquirer": "^8.2.7"
  },
  "overrides": {
    "cross-spawn": "^6.0.6"
  },
  "devDependencies": {
    "mocha": "^11.0.1",
    "mockdate": "^3.0.5",
    "nock": "^14.0.10",
    "oclif": "^4.22.81",
    "sinon": "^21.0.0",
    "standard": "^17.1.0",
    "unexpected": "^13.2.1"
  },
  "standard": {
    "ignore": [
      "workflows-repo/**"
    ]
  },
  "resolutions": {
    "serialize-javascript": "^7.0.3"
  }
}
